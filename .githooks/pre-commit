#!/usr/bin/env bash
set -euo pipefail

if [[ -x ".venv/bin/python" ]]; then
  PYTHON=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON="python3"
elif command -v python >/dev/null 2>&1; then
  PYTHON="python"
else
  echo "[pre-commit] Python not found. Please install Python and create .venv."
  exit 1
fi

echo "[pre-commit] Running ruff check..."
mapfile -t STAGED_PY_FILES < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.py$' || true)

if [[ ${#STAGED_PY_FILES[@]} -eq 0 ]]; then
  echo "[pre-commit] No staged Python files. Skipping ruff."
  exit 0
fi

"$PYTHON" -m ruff check "${STAGED_PY_FILES[@]}"

echo "[pre-commit] Running ruff format --check..."
"$PYTHON" -m ruff format --check "${STAGED_PY_FILES[@]}"

echo "[pre-commit] OK"
